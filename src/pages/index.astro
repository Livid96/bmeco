---
import data from '../data/courses.json';
---
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Modern Education</title>
</head>
<body class="bg-gray-50 text-gray-900">
    <nav class="p-4 bg-blue-600 text-white font-bold shadow-md sticky top-0 z-50">
        EduFree Portal
    </nav>

    <div class="flex flex-col md:flex-row">
        <aside class="w-full md:w-64 bg-white h-screen overflow-y-auto border-r p-4">
            {data.map((course) => (
                <div class="mb-6">
                    <h2 class="font-bold text-lg text-blue-700 uppercase">{course.subject}</h2>
                    {course.chapters.map((chap) => (
                        <div class="ml-2 mt-2">
                            <h3 class="font-semibold text-gray-600 underline text-sm">{chap.title}</h3>
                            {chap.videos.map((vid) => (
                                <button 
                                    onclick={`document.getElementById('player').src='https://www.youtube.com/embed/${vid.id}'`}
                                    class="block w-full text-left p-2 text-sm hover:bg-blue-100 rounded transition"
                                >
                                    ▶ {vid.name}
                                </button>
                            ))}
                        </div>
                    ))}
                </div>
            ))}
        </aside>

        <main class="flex-1 p-4 md:p-10">
            <div class="aspect-video w-full max-w-4xl mx-auto bg-black rounded-xl shadow-2xl overflow-hidden">
                <iframe id="player" class="w-full h-full" src="" frameborder="0" allowfullscreen></iframe>
            </div>
            <p class="mt-4 text-center text-gray-500 font-medium">Select a video from the sidebar to start learning.</p>
        </main>
    </div>
</body>
</html>
