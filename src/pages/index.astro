---
import courses from '../../data/courses.json';
export async function getStaticPaths() {
  return courses.map((c) => ({ params: { id: c.id }, props: { course: c } }));
}
const { course } = Astro.props;
---
<div class="container">
    <h1 class="faculty-title">{course.name} - Select Year</h1>
    <div class="subject-grid">
        {course.years.map((year) => (
            <a href={`/dept/${course.id}/${year.id}`} class="card">
                <div class="img-box">
                    <img src={course.image} alt={year.label} />
                </div>
                <h3>{year.label}</h3>
            </a>
        ))}
    </div>
</div>
